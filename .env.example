PORT=5000
NODE_ENV=development
# Use * to allow any frontend origin (recommended for production)
# Or comma-separated URLs: http://localhost:3000,https://your-app.vercel.app
FRONTEND_URL=*

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Sheets export (optional — per-admin OAuth)
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Enable: Google Sheets API + Google Drive API
# Redirect URI must match GOOGLE_REDIRECT_URI exactly, e.g. http://localhost:5000/api/v1/admin/google-sheets/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/admin/google-sheets/callback
# Random 32+ char secret for encrypting stored Google tokens (generate: openssl rand -hex 32)
GOOGLE_TOKEN_ENCRYPTION_KEY=
# Where to redirect after Google OAuth (frontend URL)
FRONTEND_APP_URL=http://localhost:3000
